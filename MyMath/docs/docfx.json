{
  "$schema": "https://dotnet.github.io/docfx/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "../Math.Lib/Math.Lib.csproj"
          ],
          "src": "."
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md"
        ]
      },
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      }
    ],
    "resource": [],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Math.Lib",
      "_appTitle": "Documentacion Math.Lib",
      "_enableSearch": true
    }
  }
}
